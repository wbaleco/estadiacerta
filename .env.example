# =========================================================================
# CONFIGURAÇÕES DE AMBIENTE - ESTADIACERTA BACKEND & PIPELINE VERCEL
# =========================================================================

# String de Conexão Segura com o Supabase (PostgreSQL)
# Formato padrão: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres.your_supabase_id:your_password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Chave secreta de criptografia para tokens JWT (se aplicável futuramente)
JWT_SECRET_KEY=sua_chave_secreta_super_segura_de_criptografia_jwt

# Origem de Domínios Permitidos (CORS) para Produção
ALLOWED_CORS_ORIGIN=https://estadiacerta.vercel.app
