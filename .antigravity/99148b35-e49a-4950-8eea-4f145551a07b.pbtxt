          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        const reportTitle = isAntt ? \'DETALHE DA RECLAMA\303\207\303\203O - LEI DA ESTADIA ANTT\' : \'DETALHE DA RECLAMA\303\207\303\203O - ACORDO PRIVADO\';"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
