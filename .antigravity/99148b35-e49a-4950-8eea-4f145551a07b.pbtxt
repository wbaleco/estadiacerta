          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "TOLER\303\202NCIA DE 5 HORAS: ${isExcluding ? \'APLICADA (As primeiras 5 horas de estadia foram descontadas)\' : \'N\303\203O APLICADA (Faturamento integral)\'}"
