  file_change {
    absolute_path_uri: "file:///src/components/InicioTab.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect, useRef } from \'react\';\nimport { \n  Play, \n  LogOut, \n  Gauge, \n  Upload, \n  Download, \n  Moon, \n  Wrench, \n  MapPin, \n  Clock \n} from \'lucide-react\';\nimport { LogType, ActiveJourney, HistoryEntry } from \'../types\';\n\ninterface InicioTabProps {\n  activeJourney: ActiveJourney;\n  onCheckIn: (odometer: string, reason: LogType) => void;\n  onCheckOut: (finalDuration: string) => void;\n}\n\nexport default function InicioTab({ activeJourney, onCheckIn, onCheckOut }: InicioTabProps) {\n  // checked out state variables\n  const [kmInput, setKmInput] = useState<string>(\'154200\');\n  const [selectedReason, setSelectedReason] = useState<LogType>(\'CARGA\');\n  const [errorMsg, setErrorMsg] = useState<string>(\'\');\n\n  // chronometer state variables (when checked in)\n  const [elaspedSeconds, setElapsedSeconds] = useState<number>(0);\n  const timerRef = useRef<NodeJS.Timeout | null>(null);\n\n  useEffect(() => {\n    if (activeJourney.checkedIn) {\n      // Calculate initial elapsed time\n      const computeElapsed = () => {\n        const diffMs = Date.now() - activeJourney.startTimestamp;\n        return Math.max(0, Math.floor(diffMs / 1000));\n      };\n\n      setElapsedSeconds(computeElapsed());\n\n      timerRef.current = setInterval(() => {\n        setElapsedSeconds(computeElapsed());\n      }, 1000);\n    } else {\n      if (timerRef.current) {\n        clearInterval(timerRef.current);\n        timerRef.current = null;\n      }\n      setElapsedSeconds(0);\n    }\n\n    return () => {\n      if (timerRef.current) {\n        clearInterval(timerRef.current);\n      }\n    };\n  }, [activeJourney.checkedIn, activeJourney.startTimestamp]);\n\n  // Formats seconds into HH:MM:SS\n  const formatTime = (totalSeconds: number) => {\n    const hrs = Math.floor(totalSeconds / 3600);\n    const mins = Math.floor((totalSeconds % 3600) / 60);\n    const secs = totalSeconds % 60;\n\n    return `${hrs.toString().padStart(2, \'0\')}:${mins.toString().padStart(2, \'0\')}:${secs.toString().padStart(2, \'0\')}`;\n  };\n\n  const handleCheckInClick = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!kmInput.trim()) {\n      setErrorMsg(\'Por favor, informe a quilometragem atual do ve\303\255culo.\');\n      return;\n    }\n    setErrorMsg(\'\');\n    onCheckIn(kmInput, selectedReason);\n  };\n\n  const handleCheckOutClick = () => {\n    // Generate readable duration string, e.g., \"04h 20min\" or \"00h 15min\"\n    const hrs = Math.floor(elaspedSeconds / 3600);\n    const mins = Math.floor((elaspedSeconds % 3600) / 60);\n    const durationStr = `${hrs.toString().padStart(2, \'0\')}h ${mins.toString().padStart(2, \'0\')}min`;\n    onCheckOut(durationStr);\n  };\n\n  // Get corresponding icon for reasons\n  const getReasonIcon = (reasonType: LogType, className = \"w-5 h-5\") => {\n    switch (reasonType) {\n      case \'CARGA\': return <Upload className={className} />;\n      case \'DESCARGA\': return <Download className={className} />;\n      case \'DESCANSO\': return <Moon className={className} />;\n      case \'QUEBRA\': return <Wrench className={className} />;\n      default: return <Clock className={className} />;\n    }\n  };\n\n  return (\n    <div className=\"space-y-8 pb-32 animate-fade-in\">\n      {/* 1. STATUS CARD */}\n      <section className=\"mt-2\">\n        {activeJourney.checkedIn ? (\n          <div className=\"bg-surface-card border-l-4 border-safety-yellow p-5 rounded-xl flex items-center justify-between shadow-lg\">\n            <div className=\"flex items-center gap-4\">\n              <div className=\"bg-safety-yellow/10 w-12 h-12 rounded-full flex items-center justify-center text-safety-yellow\">\n                <Clock className=\"w-6 h-6 animate-spin\" style={{ animationDuration: \'30s\' }} />\n              </div>\n              <div>\n                <h2 className=\"font-mono text-xs text-safety-yellow font-bold tracking-widest uppercase\">\n                  EM JORNADA\n                </h2>\n                <p className=\"text-on-surface font-sans font-bold text-lg\">\n                  Estadia Ativa\n                </p>\n              </div>\n            </div>\n            <span className=\"text-[10px] md:text-xs text-on-surface-variant font-mono bg-surface-container px-3 py-1.5 rounded-full uppercase tracking-wider\">\n              Falta Check-Out\n            </span>\n          </div>\n        ) : (\n          <div className=\"bg-surface-card border-l-4 border-primary-container p-5 rounded-xl flex items-center justify-between shadow-lg\">\n            <div>\n              <h2 className=\"font-mono text-xs text-on-surface-variant mb-1 uppercase tracking-widest font-bold\">\n                STATUS ATUAL\n              </h2>\n              <p className=\"font-sans text-[20px] font-bold text-on-surface\">\n                Voc\303\252 est\303\241 fora de jornada\n              </p>\n            </div>\n            <div className=\"bg-surface-container-high w-14 h-14 rounded-full flex items-center justify-center text-primary-container\">\n              <Moon className=\"w-7 h-7\" />\n            </div>\n          </div>\n        )}\n      </section>\n\n      {/* 2. MAIN TIMER OR CHECK-IN HERO ACCORDING TO STATE */}\n      {activeJourney.checkedIn ? (\n        /* ================= EM JORNADA STATE ================= */\n        <section className=\"flex flex-col items-center justify-center py-6\">\n          <div className=\"flex flex-col items-center justify-center space-y-2 mb-10 w-full text-center\">\n            <p className=\"font-mono text-xs tracking-widest text-on-surface-variant uppercase font-bold\">\n              TEMPO TOTAL DE ESTADIA\n            </p>\n            <div className=\"text-[44px] md:text-[56px] font-sans font-extrabold text-on-surface tracking-tighter tabular-nums text-center\" id=\"chronometer\">\n              {formatTime(elaspedSeconds)}\n            </div>\n          </div>\n\n          {/* Location details */}\n          <div className=\"w-full flex flex-col items-center mb-10 text-center\">\n            <div className=\"flex items-center gap-2 mb-1\">\n              <MapPin className=\"w-5 h-5 text-safety-yellow\" />\n              <p className=\"font-sans font-bold text-xl text-on-surface\">\n                {activeJourney.location}\n              </p>\n            </div>\n            <p className=\"text-on-surface-variant text-sm font-sans\">\n              {activeJourney.locationSub}\n            </p>\n          </div>\n\n          {/* Big action button */}\n          <div className=\"relative group mb-12\">\n            {/* Decortative pulse ring for glow */}\n            <div className=\"absolute inset-0 bg-status-critical/20 rounded-full blur-2xl animate-pulse scale-110\"></div>\n            <button \n              onClick={handleCheckOutClick}\n              className=\"relative w-[180px] h-[180px] rounded-full bg-status-critical border-4 border-surface text-on-surface flex flex-col items-center justify-center hero-glow-critical active:scale-95 transition-transform duration-150 cursor-pointer text-center\"\n            >\n              <LogOut className=\"w-12 h-12 text-on-surface mb-2\" />\n              <span className=\"font-sans text-lg font-extrabold tracking-wider uppercase text-on-surface\">\n                CHECK-OUT\n              </span>\n            </button>\n          </div>\n\n          {/* Check-In Summary Info Card */}\n          <div className=\"w-full bg-surface-container-low rounded-2xl p-6 border border-outline-variant/30 shadow-md\">\n            <div className=\"grid grid-cols-2 gap-6\">\n              <div className=\"flex flex-col gap-1.5 border-r border-outline-variant/20 pr-4\">\n                <span className=\"font-mono text-xs text-on-surface-variant tracking-wider uppercase\">MOTIVO</span>\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"text-safety-yellow\">\n                    {getReasonIcon(activeJourney.reason, \"w-4.5 h-4.5\")}\n                  </div>\n                  <p className=\"font-sans font-extrabold text-base text-on-surface uppercase tracking-wider\">\n                    {activeJourney.reason}\n                  </p>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5 pl-4\">\n                <span className=\"font-mono text-xs text-on-surface-variant tracking-wider uppercase\">OD\303\224METRO</span>\n                <div className=\"flex items-center gap-2\">\n                  <Gauge className=\"w-4.5 h-4.5 text-safety-yellow\" />\n                  <p className=\"font-sans font-extrabold text-base text-on-surface\">\n                    {parseInt(activeJourney.odometer).toLocaleString(\'pt-BR\')} km\n                  </p>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"mt-6 pt-4 border-t border-outline-variant/20 flex justify-between items-center text-sm\">\n              <span className=\"font-mono text-xs text-on-surface-variant tracking-wider uppercase\">IN\303\215CIO EM</span>\n              <span className=\"font-sans text-on-surface font-semibold\">{activeJourney.startTime}</span>\n            </div>\n          </div>\n        </section>\n      ) : (\n        /* ================= FORA DE JORNADA STATE ================= */\n        <section className=\"flex flex-col gap-8\">\n          {/* Action Button & Location Chip */}\n          <div className=\"flex flex-col items-center justify-center py-4\">\n            <div className=\"relative group mb-8\">\n              {/* Decorative glows */}\n              <div className=\"absolute inset-0 rounded-full bg-primary-container/20 opacity-40 animate-ping\"></div>\n              <div className=\"absolute inset-0 rounded-full bg-primary-container/10 opacity-30 animate-pulse scale-110\"></div>\n              \n              <button \n                onClick={handleCheckInClick}\n                className=\"relative w-[180px] h-[180px] md:w-[200px] md:h-[200px] rounded-full bg-primary-container text-on-primary flex flex-col items-center justify-center hero-glow active:scale-95 transition-transform duration-150 border-8 border-background cursor-pointer text-center\"\n              >\n                <Play className=\"w-12 h-12 mb-2 select-none\" fill=\"currentColor\" />\n                <span className=\"font-sans text-lg font-extrabold tracking-wider uppercase text-on-primary select-none\">\n                  CHECK-IN\n                </span>\n              </button>\n            </div>\n\n            <div className=\"bg-surface-container-high px-6 py-3 rounded-full flex items-center gap-3 border border-outline-variant/40 shadow-sm\">\n              <MapPin className=\"w-5 h-5 text-primary-container\" />\n              <span className=\"font-mono text-xs text-on-surface font-bold\">\n                Posto Graal - KM 120\n              </span>\n            </div>\n          </div>\n\n          {/* Form */}\n          <form onSubmit={handleCheckInClick} className=\"bg-surface-elevated p-6 rounded-2xl border border-outline-variant/40 flex flex-col gap-6 shadow-md\">\n            {errorMsg && (\n              <div className=\"bg-status-critical/10 text-rose-400 p-3.5 rounded-xl border border-status-critical/30 text-xs font-sans\">\n                {errorMsg}\n              </div>\n            )}\n\n            {/* Odometer Input */}\n            <div className=\"flex flex-col gap-2\">\n              <label htmlFor=\"odometer_input\" className=\"font-mono text-xs text-on-surface-variant font-bold tracking-widest uppercase ml-1\">\n                QUILOMETRAGEM ATUAL\n              </label>\n              <div className=\"relative flex items-center\">\n                <Gauge className=\"absolute left-4 w-6 h-6 text-primary-container pointer-events-none\" />\n                <input \n                  id=\"odometer_input\"\n                  className=\"w-full h-[72px] bg-background border-outline-variant border-2 rounded-xl pl-14 pr-4 font-sans font-extrabold text-xl text-on-surface focus:border-safety-yellow focus:ring-0 transition-colors\" \n                  placeholder=\"Digite o KM\" \n                  type=\"number\"\n                  value={kmInput}\n                  onChange={(e) => setKmInput(e.target.value)}\n                />\n              </div>\n            </div>\n\n            {/* Stop Reason Selection */}\n            <div className=\"flex flex-col gap-3\">\n              <label className=\"font-mono text-xs text-on-surface-variant font-bold tracking-widest uppercase ml-1\">\n                MOTIVO DA PARADA / IN\303\215CIO\n              </label>\n              \n              <div className=\"grid grid-cols-2 gap-3\">\n                <button\n                  type=\"button\"\n                  onClick={() => setSelectedReason(\'CARGA\')}\n                  className={`h-14 rounded-xl border-2 hover:bg-surface-container-highest transition-all duration-150 flex items-center justify-center gap-2.5 font-mono text-xs uppercase font-bold tracking-wider cursor-pointer ${\n                    selectedReason === \'CARGA\'\n                      ? \'border-primary-container bg-surface-container-highest text-primary-container\'\n                      : \'border-outline-variant/40 bg-surface-container text-on-surface-variant\'\n                  }`}\n                >\n                  <Upload className=\"w-4.5 h-4.5\" /> CARGA\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setSelectedReason(\'DESCARGA\')}\n                  className={`h-14 rounded-xl border-2 hover:bg-surface-container-highest transition-all duration-150 flex items-center justify-center gap-2.5 font-mono text-xs uppercase font-bold tracking-wider cursor-pointer ${\n                    selectedReason === \'DESCARGA\'\n                      ? \'border-primary-container bg-surface-container-highest text-primary-container\'\n                      : \'border-outline-variant/40 bg-surface-container text-on-surface-variant\'\n                  }`}\n                >\n                  <Download className=\"w-4.5 h-4.5\" /> DESCARGA\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setSelectedReason(\'DESCANSO\')}\n                  className={`h-14 rounded-xl border-2 hover:bg-surface-container-highest transition-all duration-150 flex items-center justify-center gap-2.5 font-mono text-xs uppercase font-bold tracking-wider cursor-pointer ${\n                    selectedReason === \'DESCANSO\'\n                      ? \'border-primary-container bg-surface-container-highest text-primary-container\'\n                      : \'border-outline-variant/40 bg-surface-container text-on-surface-variant\'\n                  }`}\n                >\n                  <Moon className=\"w-4.5 h-4.5\" /> DESCANSO\n                </button>\n\n                <button\n                  type=\"button\"\n                  onClick={() => setSelectedReason(\'QUEBRA\')}\n                  className={`h-14 rounded-xl border-2 hover:bg-surface-container-highest transition-all duration-150 flex items-center justify-center gap-2.5 font-mono text-xs uppercase font-bold tracking-wider cursor-pointer ${\n                    selectedReason === \'QUEBRA\'\n                      ? \'border-primary-container bg-surface-container-highest text-primary-container\'\n                      : \'border-outline-variant/40 bg-surface-container text-on-surface-variant\'\n                  }`}\n                >\n                  <Wrench className=\"w-4.5 h-4.5\" /> QUEBRA\n                </button>\n              </div>\n            </div>\n          </form>\n        </section>\n      )}\n\n      {/* Safety spacer */}\n      <div className=\"h-12\"></div>\n    </div>\n  );\n}\n"
