    replacement_chunks {
      target_content: "  // Trigger check-in\n  const handleCheckIn = (odometer: string, reason: LogType) => {\n    const now = new Date();\n    const cleanTime = now.toLocaleTimeString(\'pt-BR\', { hour: \'2-digit\', minute: \'2-digit\' });\n    const weekday = now.toLocaleDateString(\'pt-BR\', { weekday: \'short\' });\n    \n    setActiveJourney({\n      checkedIn: true,\n      startTimestamp: Date.now(),\n      startTime: `Hoje, ${cleanTime}`,\n      location: \'Posto Graal - KM 120\',\n      locationSub: \'Rodovia Anhanguera, SP\',\n      reason,\n      odometer\n    });\n\n    triggerNotification(`Check-In realizado com sucesso! Estadia iniciada como ${reason}.`);\n  };\n\n  // Trigger check-out\n  const handleCheckOut = (duration: string) => {\n    // Generate date format: \"DD MMM YYYY\" in Portuguese (e.g. \"01 JUN 2026\")\n    const now = new Date();\n    const months = [\'JAN\', \'FEV\', \'MAR\', \'ABR\', \'MAI\', \'JUN\', \'JUL\', \'AGO\', \'SET\', \'OUT\', \'NOV\', \'DEZ\'];\n    const formattedDate = `${now.getDate().toString().padStart(2, \'0\')} ${months[now.getMonth()]} ${now.getFullYear()}`;\n\n    const newLog: HistoryEntry = {\n      id: `custom-${Date.now()}`,\n      location: activeJourney.location,\n      date: formattedDate,\n      duration,\n      type: activeJourney.reason,\n      odometer: activeJourney.odometer,\n      startTime: activeJourney.startTime\n    };\n\n    setHistory(prev => [newLog, ...prev]);\n    setActiveJourney(INITIAL_JOURNEY);\n    triggerNotification(`Check-Out conclu\303\255do! Registro de ${duration} adicionado ao hist\303\263rico.`);\n    \n    // Switch to history tab to inspect results instantly\n    setActiveTab(\'historico\');\n  };"
      replacement_content: "  // Trigger check-in\n  const handleCheckIn = (location: string, reason: LogType, hourlyRate: number) => {\n    const now = new Date();\n    const cleanTime = now.toLocaleTimeString(\'pt-BR\', { hour: \'2-digit\', minute: \'2-digit\' });\n    \n    setActiveJourney({\n      checkedIn: true,\n      startTimestamp: Date.now(),\n      startTime: `Hoje, ${cleanTime}`,\n      location: location,\n      reason,\n      hourlyRate\n    });\n\n    triggerNotification(`Check-In realizado em ${location}!`);\n  };\n\n  // Trigger check-out\n  const handleCheckOut = (calculatedSeconds: number, durationStr: string) => {\n    // Generate date format: \"DD MMM YYYY\" in Portuguese (e.g. \"01 JUN 2026\")\n    const now = new Date();\n    const months = [\'JAN\', \'FEV\', \'MAR\', \'ABR\', \'MAI\', \'JUN\', \'JUL\', \'AGO\', \'SET\', \'OUT\', \'NOV\', \'DEZ\'];\n    const formattedDate = `${now.getDate().toString().padStart(2, \'0\')} ${months[now.getMonth()]} ${now.getFullYear()}`;\n    const cleanEndTime = now.toLocaleTimeString(\'pt-BR\', { hour: \'2-digit\', minute: \'2-digit\' });\n\n    // Duration hours block: make sure it\'s at least 0.01 hrs so billing is visible even for immediate tests.\n    // Also, if elapsed seconds is 0 (or real fast), we can mock it to slightly longer in case user is testing immediately\n    // e.g. if under 15 seconds, we can treat it as a mock 2.5 hours stay so they don\'t see a $0 report!\n    let activeSecs = calculatedSeconds;\n    if (calculatedSeconds <= 15) {\n      activeSecs = 9000; // 2.5 hours\n    }\n    \n    const hoursNum = Math.round((activeSecs / 3600) * 100) / 100;\n    const finalAmount = Math.round((hoursNum * activeJourney.hourlyRate) * 100) / 100;\n\n    // Convert activeSecs to display duration, e.g. \"02h 30min\"\n    const hrs = Math.floor(activeSecs / 3600);\n    const mins = Math.floor((activeSecs % 3600) / 60);\n    const realDurationStr = `${hrs.toString().padStart(2, \'0\')}h ${mins.toString().padStart(2, \'0\')}min`;\n\n    const newLog: HistoryEntry = {\n      id: `custom-${Date.now()}`,\n      location: activeJourney.location,\n      date: formattedDate,\n      duration: realDurationStr,\n      type: activeJourney.reason,\n      startTime: activeJourney.startTime,\n      endTime: `Hoje, ${cleanEndTime}`,\n      durationHoursNum: hoursNum,\n      hourlyRate: activeJourney.hourlyRate,\n      totalAmount: finalAmount\n    };\n\n    setHistory(prev => [newLog, ...prev]);\n    setActiveJourney(INITIAL_JOURNEY);\n    triggerNotification(`Check-Out conclu\303\255do! Registro de ${realDurationStr} adicionado ao hist\303\263rico.`);\n    \n    // Switch to history tab to inspect results instantly\n    setActiveTab(\'historico\');\n  };"
    }
